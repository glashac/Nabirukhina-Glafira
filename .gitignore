# .gitignore for Java/Maven/JavaFX Projects

# Compiled class file
*.class

# Log file
*.log
logs/

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
.flattened-pom.xml
.m2/

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# Eclipse
.classpath
.project
.settings/
bin/
.factorypath

# Gradle
.gradle/
build/

# JavaFX
javafx-sdk/
fx-mods/

# Virtual machines
*.swp
*~
.DS_Store

# Node (if frontend exists)
node_modules/
npm-debug.log
yarn-error.log

# Environment
.env
.env.local
.env.*.local

# OS
Thumbs.db
.AppleDouble
.LSOverride

# Database
*.db
*.sqlite
*.mdb
.h2.server.properties
